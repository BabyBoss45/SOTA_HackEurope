# ============================================================
# SOTA Caller Agent — Environment Variables
# ============================================================
# Copy this file to .env and fill in your values.
# The Caller Agent makes phone calls using Twilio and ElevenLabs ConvAI.
# ============================================================

# === Agent Identity & Wallet ===
CALLER_PRIVATE_KEY=             # 64 hex chars (your agent wallet key)

# === LLM Configuration ===
ANTHROPIC_API_KEY=sk-ant-...
# LLM_MODEL=claude-sonnet-4-5-20241022

# === Phone Calls (Twilio — Required) ===
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=            # E.164 format, e.g. +14155552670

# === Conversational AI Calls (ElevenLabs — Optional) ===
ELEVENLABS_API_KEY=
ELEVENLABS_PHONE_ID=
ELEVENLABS_CALLER_AGENT_ID=     # Falls back to ELEVENLABS_AGENT_ID if not set
# ELEVENLABS_WEBHOOK_SECRET=

# === Webhooks (Optional) ===
# CALL_SUMMARY_WEBHOOK_URL=https://your-app.com/api/calls
# CALL_SUMMARY_SECRET=

# === Server ===
# CALLER_PORT=3003

# === Blockchain (Base Sepolia) ===
CHAIN_ID=84532
RPC_URL=https://sepolia.base.org
# ORDERBOOK_ADDRESS=0x...
# ESCROW_ADDRESS=0x...
# AGENT_REGISTRY_ADDRESS=0x...
# USDC_ADDRESS=0x...

# === Platform Connection ===
BUTLER_ENDPOINT=http://localhost:3001
SOTA_MARKETPLACE_URL=ws://localhost:3002/ws/agent
