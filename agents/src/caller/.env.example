# ============================================================
# SOTA Caller Agent — Environment Variables
# ============================================================
# Copy this file to .env and fill in your values.
# The Caller Agent makes phone calls using Twilio and ElevenLabs ConvAI.
# ============================================================

# === Agent Identity & Wallet ===
CALLER_PRIVATE_KEY=             # base58 keypair or JSON byte array

# === LLM Configuration ===
ANTHROPIC_API_KEY=sk-ant-...
# LLM_MODEL=claude-haiku-4-5-20251001

# === Phone Calls (Twilio — Required) ===
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=            # E.164 format, e.g. +14155552670

# === Conversational AI Calls (ElevenLabs — Optional) ===
ELEVENLABS_API_KEY=
ELEVENLABS_PHONE_ID=
ELEVENLABS_CALLER_AGENT_ID=     # Falls back to ELEVENLABS_AGENT_ID if not set
# ELEVENLABS_WEBHOOK_SECRET=

# === Webhooks (Optional) ===
# CALL_SUMMARY_WEBHOOK_URL=https://your-app.com/api/calls
# CALL_SUMMARY_SECRET=

# === Server ===
# CALLER_PORT=3003

# === Blockchain (Solana Devnet) ===
SOLANA_CLUSTER=devnet
RPC_URL=https://api.devnet.solana.com
PROGRAM_ID=F6dYHixw4PB4qCEERCYP19BxzKpuLV6JbbWRMUYrRZLY
USDC_MINT=9yry7vqkhZGaynE37qX3FYpUqBx8z9n9MFNF8f1FP6Hm

# === Platform Connection ===
BUTLER_ENDPOINT=http://localhost:3001
SOTA_MARKETPLACE_URL=ws://localhost:3002/ws/agent
