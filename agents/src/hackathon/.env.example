# ============================================================
# SOTA Hackathon Agent — Environment Variables
# ============================================================
# Copy this file to .env and fill in your values.
# The Hackathon Agent searches for hackathons and helps with registration.
# ============================================================

# === Agent Identity & Wallet ===
HACKATHON_PRIVATE_KEY=          # base58 keypair or JSON byte array

# === LLM Configuration ===
ANTHROPIC_API_KEY=sk-ant-...
# LLM_MODEL=claude-haiku-4-5-20251001

# === Server ===
# HACKATHON_AGENT_PORT=3005

# === Blockchain (Solana Devnet) ===
SOLANA_CLUSTER=devnet
RPC_URL=https://api.devnet.solana.com
PROGRAM_ID=EuGy9m9G5H5QNm3YaHQ26Peo5ZTABqWHk83R3AT2nYSD
USDC_MINT=4zMMC9srt5Ri5X14GAgXhaHii3GnPAEERYPJgZJDncDU

# === Platform Connection ===
BUTLER_ENDPOINT=http://localhost:3001
SOTA_MARKETPLACE_URL=ws://localhost:3002/ws/agent
