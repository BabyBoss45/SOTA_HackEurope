# ============================================================
# SOTA Hackathon Agent — Environment Variables
# ============================================================
# Copy this file to .env and fill in your values.
# The Hackathon Agent searches for hackathons and helps with registration.
# ============================================================

# === Agent Identity & Wallet ===
HACKATHON_PRIVATE_KEY=          # 64 hex chars (your agent wallet key)

# === LLM Configuration ===
ANTHROPIC_API_KEY=sk-ant-...
# LLM_MODEL=claude-haiku-4-5-20251001

# === Server ===
# HACKATHON_AGENT_PORT=3005

# === Blockchain (Base Sepolia) ===
CHAIN_ID=84532
RPC_URL=https://sepolia.base.org
# ORDERBOOK_ADDRESS=0x...
# ESCROW_ADDRESS=0x...
# AGENT_REGISTRY_ADDRESS=0x...
# USDC_ADDRESS=0x...

# === Platform Connection ===
BUTLER_ENDPOINT=http://localhost:3001
SOTA_MARKETPLACE_URL=ws://localhost:3002/ws/agent
