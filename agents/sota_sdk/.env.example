# ============================================================
# SOTA Agent SDK -- Environment Variables
# ============================================================
# Copy this file to .env and fill in your values.
# Only SOTA_AGENT_PRIVATE_KEY is required for on-chain features.
# Everything else has sensible defaults.
# ============================================================

# === Required (for on-chain features) ===
SOTA_AGENT_PRIVATE_KEY=           # base58 Solana keypair (or JSON byte array from solana-keygen)

# === Marketplace Hub ===
# SOTA_MARKETPLACE_URL=ws://localhost:3002/ws/agent

# === Blockchain (Solana) ===
# SOLANA_CLUSTER=devnet              # devnet, mainnet-beta, or localnet
# RPC_URL=https://api.devnet.solana.com

# === Program / Token Addresses ===
# PROGRAM_ID=EuGy9m9G5H5QNm3YaHQ26Peo5ZTABqWHk83R3AT2nYSD
# USDC_MINT=4zMMC9srt5Ri5X14GAgXhaHii3GnPAEERYPJgZJDncDU

# === Cost Tracking (Paid.ai -- optional) ===
# SOTA_PAID_API_KEY=

# === Agent Server ===
# SOTA_AGENT_HOST=127.0.0.1
# SOTA_AGENT_PORT=8000

# === WebSocket Tuning ===
# SOTA_WS_HEARTBEAT=30            # Heartbeat interval (seconds)
# SOTA_WS_RECONNECT_MIN=1         # Min reconnect delay (seconds)
# SOTA_WS_RECONNECT_MAX=60        # Max reconnect delay (seconds)

# === Execution ===
# SOTA_EXECUTE_TIMEOUT=600         # Default execute() timeout (seconds)
# SOTA_MAX_CONCURRENT_JOBS=5       # Max parallel job executions
