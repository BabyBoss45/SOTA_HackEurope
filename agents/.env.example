# =============================================================================
# NETWORK (Base Sepolia)
# =============================================================================
RPC_URL=https://sepolia.base.org
CHAIN_ID=84532
PRIVATE_KEY=

# =============================================================================
# AGENT WALLETS
# Each agent has its own wallet for transactions and signing
# Generate with: python -c "from eth_account import Account; a = Account.create(); print(f'Address: {a.address}\nKey: {a.key.hex()}')"
# =============================================================================
MANAGER_PRIVATE_KEY=
CALLER_PRIVATE_KEY=

# =============================================================================
# LLM PROVIDER
# =============================================================================
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# =============================================================================
# EXTERNAL APIS
# =============================================================================

# Twilio (for phone calls)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=+1XXXXXXXXXX

# ElevenLabs (voice AI)
ELEVENLABS_API_KEY=

# =============================================================================
# AGENT A2A ENDPOINTS
# =============================================================================
MANAGER_ENDPOINT=http://localhost:3001
CALLER_ENDPOINT=http://localhost:3003

# Agent server ports
MANAGER_PORT=3001
CALLER_PORT=3003
BUTLER_API_PORT=3001

# =============================================================================
# SMART CONTRACT ADDRESSES (Base Sepolia)
# Filled after deployment (see contracts/deployments/)
# =============================================================================
ORDERBOOK_ADDRESS=
ESCROW_ADDRESS=
AGENT_REGISTRY_ADDRESS=
USDC_ADDRESS=

# =============================================================================
# BIDDING CONFIGURATION
# =============================================================================
MIN_PROFIT_MARGIN=0.10
MAX_CONCURRENT_JOBS=5
AUTO_BID_ENABLED=true

# =============================================================================
# VECTOR DB / MEMORY (optional)
# =============================================================================
QDRANT_URL=
MEM0_API_KEY=

# =============================================================================
# INCIDENT.IO (optional — graceful no-op if not configured)
# =============================================================================
INCIDENT_IO_API_KEY=              # Bearer token from incident.io dashboard
INCIDENT_IO_ALERT_SOURCE_ID=      # HTTP alert source config ID (for Alert Events V2)
INCIDENT_IO_WEBHOOK_SECRET=       # Svix webhook secret for signature verification
# INCIDENT_IO_SEVERITY_MAP=       # Optional JSON override: {"critical":"...","high":"...",...}
