# Chain (Solana Devnet)
SOLANA_CLUSTER=devnet
RPC_URL=https://api.devnet.solana.com
PRIVATE_KEY=           # base58-encoded keypair or 64-byte JSON array

# Program (deployed on Solana Devnet)
PROGRAM_ID=EuGy9m9G5H5QNm3YaHQ26Peo5ZTABqWHk83R3AT2nYSD
USDC_MINT=4zMMC9srt5Ri5X14GAgXhaHii3GnPAEERYPJgZJDncDU

# LLM
ANTHROPIC_API_KEY=sk-ant-...

# Vector DB (Qdrant — externally provisioned)
QDRANT_URL=https://your-qdrant-instance
QDRANT_API_KEY=

# CORS (both Vercel frontend URLs)
CORS_ALLOWED_ORIGINS=https://main-app.vercel.app,https://mobile-app.vercel.app

# Refund callback (main web app URL)
NEXTJS_BASE_URL=https://main-app.vercel.app

# External services (optional)
ELEVENLABS_API_KEY=
ELEVENLABS_AGENT_ID=
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=
INCIDENT_IO_API_KEY=
SOTA_PAID_API_KEY=
