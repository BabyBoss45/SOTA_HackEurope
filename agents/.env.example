# Database (Railway PostgreSQL)
DATABASE_URL=postgresql://user:password@host:5432/sota

# Chain (Solana Devnet)
SOLANA_CLUSTER=devnet
RPC_URL=https://api.devnet.solana.com
PRIVATE_KEY=           # base58-encoded keypair or 64-byte JSON array

# Program (deployed on Solana Devnet)
PROGRAM_ID=F6dYHixw4PB4qCEERCYP19BxzKpuLV6JbbWRMUYrRZLY
USDC_MINT=9yry7vqkhZGaynE37qX3FYpUqBx8z9n9MFNF8f1FP6Hm

# LLM
ANTHROPIC_API_KEY=sk-ant-...

# Vector DB (Qdrant — externally provisioned)
QDRANT_URL=https://your-qdrant-instance
QDRANT_API_KEY=

# CORS (both Vercel frontend URLs)
CORS_ALLOWED_ORIGINS=https://main-app.vercel.app,https://mobile-app.vercel.app

# Refund callback (main web app URL)
NEXTJS_BASE_URL=https://main-app.vercel.app

# External services (optional)
ELEVENLABS_API_KEY=
ELEVENLABS_AGENT_ID=
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=
INCIDENT_IO_API_KEY=
SOTA_PAID_API_KEY=
BUTLER_AUTO_CONFIRM=true

