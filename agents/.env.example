# ============================================================
# SOTA Marketplace — Unified Environment Variables
# ============================================================
# Copy to .env and fill in your values.
# One file for Butler API + all 7 agents (single Railway deploy).
# ============================================================

# ── Database ─────────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@host:5432/sota

# ── Blockchain (Solana Devnet) ───────────────────────────────
SOLANA_CLUSTER=devnet
RPC_URL=https://api.devnet.solana.com
PROGRAM_ID=F6dYHixw4PB4qCEERCYP19BxzKpuLV6JbbWRMUYrRZLY
USDC_MINT=9yry7vqkhZGaynE37qX3FYpUqBx8z9n9MFNF8f1FP6Hm

# ── LLM ──────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
# LLM_MODEL=claude-sonnet-4-6             # optional override

# LLM (OpenAI — Competitor Fun Agent / GPT-4o)
OPENAI_API_KEY=sk-proj-...
OPENAI_MODEL=gpt-4o

# ── Marketplace Hub ──────────────────────────────────────────
# Agents connect to the Hub via WebSocket for bidding.
# For Railway internal networking:  ws://sota-butler-api.railway.internal:3001/hub/ws/agent
# For local dev:                    ws://localhost:3001/hub/ws/agent
SOTA_HUB_URL=ws://localhost:3001/hub/ws/agent
BUTLER_ENDPOINT=http://localhost:3001
BUTLER_AUTO_CONFIRM=true

# ── Agent Wallets (one per agent) ────────────────────────────
# Each agent needs its own Solana keypair for on-chain bidding.
# Format: base58 string, base64 string, or JSON byte array.
# If an agent-specific key is not set, it falls back to PRIVATE_KEY.
PRIVATE_KEY=                              # Butler wallet
CALLER_PRIVATE_KEY=                       # Caller agent
HACKATHON_PRIVATE_KEY=                    # Hackathon agent
GIFT_PRIVATE_KEY=                         # Gift Suggestion agent
RESTAURANT_PRIVATE_KEY=                   # Restaurant Booker agent
REFUND_PRIVATE_KEY=                       # Refund Claim agent
SHOPPER_PRIVATE_KEY=                      # Smart Shopper agent
TRIP_PRIVATE_KEY=                         # Trip Planner agent

# ── Caller Agent (Twilio + ElevenLabs) ───────────────────────
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=                      # E.164 format: +14155552670
ELEVENLABS_API_KEY=
ELEVENLABS_AGENT_ID=
ELEVENLABS_PHONE_ID=
ELEVENLABS_CALLER_AGENT_ID=              # falls back to ELEVENLABS_AGENT_ID
# ELEVENLABS_WEBHOOK_SECRET=
# CALL_SUMMARY_WEBHOOK_URL=
# CALL_SUMMARY_SECRET=

# ── Search (SerpAPI) ─────────────────────────────────────────
# Used by: gift_suggestion, smart_shopper, restaurant_booker, trip_planner
SERPAPI_API_KEY=

# ── Google Calendar (Restaurant Booker) ──────────────────────
# GOOGLE_OAUTH_CLIENT_ID=
# GOOGLE_OAUTH_CLIENT_SECRET=

# ── Vector DB (Qdrant) ───────────────────────────────────────
QDRANT_URL=
QDRANT_API_KEY=

# ── Memory (Mem0) ────────────────────────────────────────────
# MEM0_API_KEY=

# ── Observability ────────────────────────────────────────────
# INCIDENT_IO_API_KEY=
# INCIDENT_IO_ALERT_SOURCE_ID=
SOTA_PAID_API_KEY=

# ── CORS ─────────────────────────────────────────────────────
CORS_ALLOWED_ORIGINS=https://main-app.vercel.app,https://mobile-app.vercel.app
NEXTJS_BASE_URL=https://main-app.vercel.app

# ── Server Ports (defaults shown — Railway overrides PORT) ───
# PORT=3001                               # Butler API
# CALLER_PORT=3003
# HACKATHON_AGENT_PORT=3005
# GIFT_AGENT_PORT=3007
# RESTAURANT_AGENT_PORT=3008
# REFUND_AGENT_PORT=3009
# SHOPPER_AGENT_PORT=3010
# TRIP_AGENT_PORT=3011
