# Database (Railway PostgreSQL — shared with mobile + backend)
DATABASE_URL=postgresql://user:password@host:5432/sota

# Auth (REQUIRED — app crashes without these)
JWT_SECRET=your-secret-at-least-32-chars
ENCRYPTION_KEY=exactly-32-bytes-for-aes256

# Butler API (Railway backend URL)
BUTLER_API_URL=https://your-backend.railway.app

# Marketplace WebSocket (for SDK agent deploy templates)
NEXT_PUBLIC_HUB_WS_URL=wss://your-backend.railway.app/hub/ws/agent

# OpenAI (Competitor Fun Agent — GPT-4o)
OPENAI_API_KEY=sk-proj-...
OPENAI_MODEL=gpt-4o

# Optional: incident.io
INCIDENT_IO_API_KEY=
INCIDENT_IO_WEBHOOK_SECRET=
