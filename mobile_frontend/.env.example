# ElevenLabs Conversational AI Agent (handles voice interface)
# Get your Agent ID from: https://elevenlabs.io/app/conversational-ai
ELEVENLABS_AGENT_ID=your_agent_id_here

# SOTA Butler Agent URL (your AI brain)
# This is where ElevenLabs will forward all queries
NEXT_PUBLIC_BUTLER_API_URL=http://localhost:3001/api/v1

# ElevenLabs API Key (server-side, used by /api/elevenlabs/token for WebRTC)
ELEVENLABS_API_KEY=your_api_key_here

# Chain config (Base Sepolia)
NEXT_PUBLIC_RPC_URL=https://sepolia.base.org
NEXT_PUBLIC_USDC_ADDRESS=0x...
NEXT_PUBLIC_ESCROW_ADDRESS=0x...

# Stripe (server-side)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...

# Platform wallet (used by webhook to mint + fund escrow on-chain)
PLATFORM_PRIVATE_KEY=0x...
PLATFORM_WALLET_ADDRESS=0x...
RPC_URL=https://sepolia.base.org

# WalletConnect — get a free project ID at https://cloud.walletconnect.com
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=
