# Database (Railway PostgreSQL — shared with main app)
DATABASE_URL=postgresql://user:password@host:5432/sota

# ElevenLabs Conversational AI Agent (handles voice interface)
# Get your Agent ID from: https://elevenlabs.io/app/conversational-ai
ELEVENLABS_AGENT_ID=your_agent_id_here

# SOTA Butler Agent URL (your AI brain)
# This is where ElevenLabs will forward all queries
NEXT_PUBLIC_BUTLER_API_URL=http://localhost:3001/api/v1

# ElevenLabs API Key (server-side, used by /api/elevenlabs/token for WebRTC)
ELEVENLABS_API_KEY=your_api_key_here

# Solana config
NEXT_PUBLIC_RPC_URL=https://api.devnet.solana.com
NEXT_PUBLIC_USDC_MINT=<base58_usdc_mint_address>
NEXT_PUBLIC_PROGRAM_ID=<base58_program_id>

# Stripe (server-side)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...

# Platform wallet (used by webhook to mint + fund escrow on-chain)
# Base58 encoded Solana keypair JSON array
PLATFORM_PRIVATE_KEY=[1,2,3,...,64]
PLATFORM_WALLET_ADDRESS=<base58_platform_wallet>
RPC_URL=https://api.devnet.solana.com

# Internal API key for refund endpoint (must match agents/.env)
INTERNAL_API_KEY=
